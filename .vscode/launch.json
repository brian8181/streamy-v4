{
  "name": "C++ Launch",
  "type": "cppdbg",
  "request": "launch",
  "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
  "args": ["test/test5.txt"],
  "environment": [{ "name": "config", "value": "Debug" }],
  "cwd": "${workspaceFolder}"
