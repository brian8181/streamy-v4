{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/build",
                "${workspaceFolder}/src"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE"
            ],
            "windowsSdkVersion": "10.0.22621.0",
            "compilerPath": "C:/cygwin64/bin/g++.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "configurationProvider": "ms-vscode.cmake-tools",
            "recursiveIncludes": {
                "reduce": "never"
            },
            "intelliSenseMode": "linux-gcc-x64",
            "mergeConfigurations": true
        }
    ],
    "version": 4
}
