{
  "tasks": [
    {
      "label": "cygwin_shell",
      "type": "shell",
      "command": "C:\\cygwin64\\bin\\mintty.exe",
       "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
			"windows": {
    			"MIMode": "gdb",
    			"miDebuggerPath": "C:\\cygwin64\\bin\\gdb.exe"
  			},
            "detail": "Task generated by Debugger."
    },
	{
		"label": "MAKE DEBUGGDB",
		"type": "shell",
		"command": "make -f ${workspaceFolder}/makefile",
		"problemMatcher": [
			"$gcc"
		],
		"group": {
			"kind": "build",
			"isDefault": true
		}
	}
],
"version": "2.0.0"
}
